# ================================================================================
# LLM 提供者選擇
# ================================================================================
# 設置為 true 使用 Gemini API，設置為 false 使用 Ollama 本地模型
GEMINI_ENABLED=true

# ================================================================================
# Gemini API 配置（使用 Gemini 模式時需要）
# ================================================================================
# 從 https://aistudio.google.com/app/apikey 獲取 API Key
GEMINI_API_KEY=AIzaSyDG-xUTBIpo06-wlQD3gjQTZ_wPmTDJ47E

# Gemini 模型選擇
# 推薦使用 gemini-3-flash-preview（免費版，性能優秀）
GEMINI_MODEL_SCAMMER=gemini-3-flash-preview
GEMINI_MODEL_VICTIM=gemini-3-flash-preview
GEMINI_MODEL_EXPERT=gemini-3-flash-preview
GEMINI_MODEL_RECORDER=gemini-3-flash-preview

# Gemini 生成參數（可選）
GEMINI_TEMPERATURE=0.7
GEMINI_TOP_P=0.95
GEMINI_TOP_K=40
GEMINI_MAX_OUTPUT_TOKENS=2048
GEMINI_TIMEOUT=60.0
GEMINI_MAX_RETRIES=3

# ================================================================================
# Ollama 配置（使用 Ollama 模式時需要）
# ================================================================================
# Agent 專業化配置 - 每個 Agent 使用不同的模型
AGENT_MODEL=gemma3:4b
AGENT_MODEL_VICTIM=gemma3:4b
AGENT_MODEL_SCAMMER=anti-fraud-scammer-20251117_173453
AGENT_MODEL_EXPERT=anti-fraud-expert-20251117_173453
AGENT_MODEL_RECORDER=gemma3:4b

# 本地開發環境（不使用 Docker）
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_BASE_URL_SCAMMER=http://127.0.0.1:11434
OLLAMA_BASE_URL_VICTIM=http://127.0.0.1:11434
OLLAMA_BASE_URL_EXPERT=http://127.0.0.1:11434
OLLAMA_BASE_URL_RECORDER=http://127.0.0.1:11434

# Docker 環境使用（使用 docker-compose 時請取消註釋下面的配置）
# OLLAMA_BASE_URL=http://ollama:11434
# OLLAMA_BASE_URL_SCAMMER=http://ollama:11434
# OLLAMA_BASE_URL_VICTIM=http://ollama:11434
# OLLAMA_BASE_URL_EXPERT=http://ollama:11434
# OLLAMA_BASE_URL_RECORDER=http://ollama:11434

# Ollama 生成參數
OLLAMA_TEMPERATURE=0.5
OLLAMA_TOP_P=0.85
OLLAMA_REPEAT_PENALTY=1.1
OLLAMA_NUM_CTX=4096
OLLAMA_NUM_PREDICT=2000
OLLAMA_AUTO_PULL=1

# ================================================================================
# 其他配置
# ================================================================================
# 自動訓練
AUTO_TRAIN_ENABLED=true

# 使用簡化 Prompt（減少 Token 使用）
USE_SIMPLE_PROMPTS=false

# 日誌級別（debug, info, warning, error）
LOG_LEVEL=info

# 強制使用 GPU（0=否, 1=是）
FORCE_GPU=0