# Backend Environment Variables
FLASK_ENV={{ env_vars.FLASK_ENV | default('production') }}
FLASK_APP=app.py
SECRET_KEY={{ backend_api_key }}
API_KEY={{ backend_api_key }}

# OpenAI Configuration
OPENAI_API_KEY={{ env_vars.OPENAI_API_KEY | default('') }}

# Database Configuration
DB_TYPE={{ db_type }}
DB_NAME={{ db_name }}
DB_USER={{ db_user }}
DB_PASSWORD={{ db_password }}
DB_HOST={{ db_host }}
DB_PORT={{ db_port }}

# Server Configuration
HOST=0.0.0.0
PORT={{ backend_port }}

# Logging
LOG_LEVEL=INFO
LOG_FILE={{ log_dir }}/backend.log

# CORS
CORS_ORIGINS=http://{{ frontend_domain }}:{{ frontend_port }}
