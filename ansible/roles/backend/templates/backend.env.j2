# ============================================================
# backend/.env — generated by Ansible
# DO NOT edit manually — managed by Ansible template
# ============================================================

# ── LLM Provider ────────────────────────────────────────────
GEMINI_ENABLED={{ 'true' if gemini_enabled else 'false' }}

# ── Gemini ───────────────────────────────────────────────────
GEMINI_API_KEY={{ gemini_api_key | default('') }}
GEMINI_MODEL_SCAMMER={{ gemini_model_scammer | default('gemini-2.5-flash') }}
GEMINI_MODEL_EXPERT={{ gemini_model_expert | default('gemini-2.5-flash') }}
GEMINI_MODEL_VICTIM={{ gemini_model_victim | default('gemini-2.5-flash') }}
GEMINI_MODEL_RECORDER={{ gemini_model_recorder | default('gemini-2.5-flash') }}
GEMINI_MAX_OUTPUT_TOKENS={{ gemini_max_output_tokens | default(800) }}
GEMINI_TIMEOUT={{ gemini_timeout | default(45.0) }}
GEMINI_MAX_RETRIES=2
GEMINI_TEMPERATURE=0.7

# ── Ollama ───────────────────────────────────────────────────
OLLAMA_BASE_URL={{ ollama_base_url }}
AGENT_MODEL={{ ollama_model }}
AGENT_MODEL_SCAMMER={{ agent_model_scammer }}
AGENT_MODEL_EXPERT={{ agent_model_expert }}
AGENT_MODEL_VICTIM={{ agent_model_victim }}
AGENT_MODEL_RECORDER={{ agent_model_recorder }}
OLLAMA_NUM_CTX={{ ollama_num_ctx }}
OLLAMA_NUM_PREDICT={{ ollama_num_predict }}
OLLAMA_TEMPERATURE={{ ollama_temperature }}
OLLAMA_TOP_P=0.85
OLLAMA_REPEAT_PENALTY=1.1
OLLAMA_AUTO_PULL=0

# ── Application ──────────────────────────────────────────────
APP_ENV={{ 'production' if deploy_mode != 'local' else 'development' }}
LOG_LEVEL={{ log_level | default('info') }}
FORCE_GPU={{ force_gpu | default(0) }}
PORT={{ backend_port }}
