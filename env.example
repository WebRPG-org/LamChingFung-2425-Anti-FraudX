# ============================================
# LLM 提供者選擇
# ============================================
GEMINI_ENABLED=false  # true=使用Gemini, false=使用Ollama

# ============================================
# Gemini API 配置
# ============================================
GEMINI_API_KEY=your_api_key_here

# Gemini 模型選擇
# 推薦使用 gemini-3-flash-preview（免費版，性能優秀）
# 其他選項: gemini-2.0-flash-exp, gemini-1.5-flash, gemini-1.5-pro
GEMINI_MODEL_SCAMMER=gemini-3-flash-preview
GEMINI_MODEL_VICTIM=gemini-3-flash-preview
GEMINI_MODEL_EXPERT=gemini-3-flash-preview
GEMINI_MODEL_RECORDER=gemini-3-flash-preview

# Gemini 生成參數
GEMINI_TEMPERATURE=0.7
GEMINI_TOP_P=0.95
GEMINI_TOP_K=40
GEMINI_MAX_OUTPUT_TOKENS=2048
GEMINI_TIMEOUT=60.0
GEMINI_MAX_RETRIES=3

# ============================================
# Ollama 配置（保留向後兼容）
# ============================================
AGENT_MODEL=gemma3:4b
OLLAMA_BASE_URL=http://localhost:11434

# 可選：為每個 Agent 指定不同的模型
AGENT_MODEL_SCAMMER=gemma3:4b
AGENT_MODEL_VICTIM=gemma3:4b
AGENT_MODEL_EXPERT=gemma3:4b
AGENT_MODEL_RECORDER=gemma3:4b

# 可選：為每個 Agent 指定不同的 Ollama 實例
OLLAMA_BASE_URL_SCAMMER=http://localhost:11434
OLLAMA_BASE_URL_VICTIM=http://localhost:11434
OLLAMA_BASE_URL_EXPERT=http://localhost:11434
OLLAMA_BASE_URL_RECORDER=http://localhost:11434

# Ollama 生成參數
OLLAMA_TEMPERATURE=0.5
OLLAMA_TOP_P=0.85
OLLAMA_REPEAT_PENALTY=1.1
OLLAMA_NUM_CTX=4096
OLLAMA_NUM_PREDICT=2000
OLLAMA_AUTO_PULL=1

# ============================================
# 其他配置
# ============================================
AUTO_TRAIN_ENABLED=true
USE_SIMPLE_PROMPTS=false
LOG_LEVEL=info
FORCE_GPU=0
