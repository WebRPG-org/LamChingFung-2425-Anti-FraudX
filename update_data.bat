@echo off
chcp 65001 > nul
cd /d "%~dp0"

echo ================================================================================
echo 自動化數據更新 - 單次運行
echo ================================================================================
echo.

echo [INFO] 此腳本將執行以下操作：
echo   1. 運行 scraper 抓取最新詐騙案例
echo   2. 更新精簡版數據（lite 和 ultra_lite）
echo   3. 重建 RAG 向量數據庫
echo.
echo [INFO] 預計需要 5-10 分鐘
echo.

set /p CONFIRM="確定要開始更新嗎？(Y/N): "
if /i not "%CONFIRM%"=="Y" (
    echo 已取消
    pause
    exit /b 0
)

echo.
echo ================================================================================
echo 開始更新...
echo ================================================================================
echo.

cd backend
py scripts/auto_update_data.py --mode once

if %errorlevel% equ 0 (
    echo.
    echo ================================================================================
    echo ✅ 更新完成！
    echo ================================================================================
    echo.
    echo 已更新：
    echo   - scraped_alerts.json （完整版）
    echo   - scraped_alerts_lite.json （30 案例）
    echo   - scraped_alerts_ultra_lite.json （5 案例）
    echo   - RAG 向量數據庫
    echo.
) else (
    echo.
    echo ================================================================================
    echo ❌ 更新失敗
    echo ================================================================================
    echo.
    echo 請檢查錯誤信息並重試
    echo.
)

pause
